{"ast":null,"code":"import{useEffect,useMemo,useState}from\"react\";import{adminService}from\"../services/adminService\";import{getCityFilterParams}from\"../components/AdminDateFilter\";export const useAdminCityFilter=()=>{const[selectedCity,setSelectedCity]=useState(\"all\");const[cities,setCities]=useState([]);useEffect(()=>{const loadCities=async()=>{try{const data=await adminService.getCities();setCities(data||[]);}catch(error){setCities([]);}};loadCities();},[]);const cityParams=useMemo(()=>getCityFilterParams(selectedCity),[selectedCity]);return{cities,selectedCity,setSelectedCity,cityParams};};","map":{"version":3,"names":["useEffect","useMemo","useState","adminService","getCityFilterParams","useAdminCityFilter","selectedCity","setSelectedCity","cities","setCities","loadCities","data","getCities","error","cityParams"],"sources":["/Users/amirmirza/Desktop/Dev/ClickDeliverAll/admin-panel/src/hooks/useAdminCityFilter.js"],"sourcesContent":["import { useEffect, useMemo, useState } from \"react\";\nimport { adminService } from \"../services/adminService\";\nimport { getCityFilterParams } from \"../components/AdminDateFilter\";\n\nexport const useAdminCityFilter = () => {\n  const [selectedCity, setSelectedCity] = useState(\"all\");\n  const [cities, setCities] = useState([]);\n\n  useEffect(() => {\n    const loadCities = async () => {\n      try {\n        const data = await adminService.getCities();\n        setCities(data || []);\n      } catch (error) {\n        setCities([]);\n      }\n    };\n\n    loadCities();\n  }, []);\n\n  const cityParams = useMemo(\n    () => getCityFilterParams(selectedCity),\n    [selectedCity],\n  );\n\n  return {\n    cities,\n    selectedCity,\n    setSelectedCity,\n    cityParams,\n  };\n};\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,OAAO,CAAEC,QAAQ,KAAQ,OAAO,CACpD,OAASC,YAAY,KAAQ,0BAA0B,CACvD,OAASC,mBAAmB,KAAQ,+BAA+B,CAEnE,MAAO,MAAM,CAAAC,kBAAkB,CAAGA,CAAA,GAAM,CACtC,KAAM,CAACC,YAAY,CAAEC,eAAe,CAAC,CAAGL,QAAQ,CAAC,KAAK,CAAC,CACvD,KAA